// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js" // use js client instead of edge client recomended by docs
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  players       TeamPlayer[]

  // Friendship
  friendCode           String       @unique @default(uuid())
  friendshipsInitiated Friendship[] @relation("FriendshipRequester")
  friendshipsReceived  Friendship[] @relation("FriendshipAddressee")

  ownedParty  Party?       @relation("PartyOwner")
  partyMember PartyMember? // the slot they occupy in someone

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model InfraTestKv {
  id  BigInt @id
  val String

  @@map("infra_test_kv")
}

enum FriendshipStatus {
  PENDING // requester sent, addressee hasn't responded
  ACCEPTED
  DECLINED // kept for cooldown / block logic
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@map("friendship")
}

model Party {
  id        String   @id @default(uuid())
  ownerId   String   @unique // 1-to-1 with User — you own exactly one party
  createdAt DateTime @default(now())

  owner  User         @relation("PartyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  member PartyMember? // the single guest slot

  @@map("party")
}

model PartyMember {
  id       String   @id @default(uuid())
  partyId  String   @unique // only one member row per party
  userId   String   @unique // a user can only be a guest in one party at a time
  joinedAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("party_member")
}

enum GameStatus {
  WAITING
  STARTING
  ACTIVE
  FLIPPING
  FINISHED
  CANCELLED
}

enum GameType {
  TWOPLAYER
  FOURPLAYER
}

model GameRoom {
  id         String      @id @default(uuid())
  status     GameStatus  @default(STARTING)
  createdAt  DateTime    @default(now()) @map("created_at")
  endedAt    DateTime?
  problemId  String
  gameType   GameType
  problem    Problem     @relation(fields: [problemId], references: [id])
  teams      Team[]
  gameResult GameResult?

  @@index([problemId])
  @@map("game_rooms")
}

model Team {
  id         String       @id @default(uuid())
  gameRoomId String
  createdAt  DateTime     @default(now())
  gameRoom   GameRoom     @relation(fields: [gameRoomId], references: [id], onDelete: Cascade)
  players    TeamPlayer[]
  wonGame    GameResult?  @relation("WinningTeamRelation")

  @@index([gameRoomId])
}

enum Role {
  CODER
  TESTER
  SPECTATOR
}

model TeamPlayer {
  teamId String
  userId String
  role   Role
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum ProblemDifficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id               String            @id @default(uuid())
  title            String
  slug             String
  description      String
  topics           String[]
  difficulty       ProblemDifficulty
  successRate      Float
  totalSubmissions Int
  totalAccepted    Int
  likes            Int
  dislikes         Int
  starterCode      String?
  hints            String?

  gameRooms GameRoom[]
  tests     ProblemTest[]

  @@unique([slug])
  @@index([title])
  @@index([slug])
  @@map("problem")
}

model ProblemTest {
  id             String @id @default(uuid())
  problemId      String
  functionInput  Json // Strongly typed in the frontend
  expectedOutput Json // ^^
  language       String
  optimalTimeMs  Int

  problem Problem @relation(fields: [problemId], references: [slug], onDelete: Cascade)
}

model GameTest {
  id             String   @id @default(uuid())
  gameRoomId     String   // Direct reference for efficient filtering
  gameResultId   String
  testCaseId     String   // Changed from Int to match ProblemTest.id
  position       Int
  teamNumber     Int      // Required: team 1 or 2. NOTE: Hidden testcases are duplicated per team
  functionInput  Json
  expectedOutput Json

  // Execution Results
  actualOutput   Json?           // Computed output from execution
  passed         Boolean?        // Test pass/fail
  stderr         String?         // Captures full stderr output from execution
  executionTimeMs Int?           // Individual test execution time in ms

  // Classification
  type           String   @default("Game") // "Game" (player submitted) or "Hidden" (DB held for grading)
  createdAt      DateTime @default(now())  // Audit trail

  gameResult GameResult @relation(fields: [gameResultId], references: [id], onDelete: Cascade)

  @@index([gameRoomId])
  @@index([gameResultId])
  @@index([gameResultId, teamNumber])
  @@index([gameResultId, teamNumber, type]) // For filtering by test type
  @@index([gameRoomId, teamNumber])         // For game-level filtering
  @@unique([gameResultId, teamNumber, position])
  @@unique([gameResultId, teamNumber, testCaseId])
}

model GameResult {
  id            String  @id @default(uuid())
  gameRoomId    String  @unique
  winningTeamId String? @unique
  team1Code     String?
  team2Code     String?
  gameTests     GameTest[]
  team1SubmittedAt   String?
  team2SubmittedAt   String?

  winningTeam Team?    @relation("WinningTeamRelation", fields: [winningTeamId], references: [id])
  gameRoom    GameRoom @relation(fields: [gameRoomId], references: [id], onDelete: Cascade)

  @@index([winningTeamId])
}
